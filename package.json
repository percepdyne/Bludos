{
  "name": "bludos",
  "productName": "Bludos",
  "version": "0.2.0",
  "description": "Bludos (blue dossier) — local-first design documentation & inspiration archive for product designers",
  "main": "electron/main.cjs",
  "scripts": {
    "templates": "node scripts/build-templates.mjs",
    "icon": "node scripts/make-icon.mjs",
    "build": "npm run templates && vite build",
    "start": "npm run build && electron .",
    "app": "electron .",
    "dist": "npm run build && npm run icon && electron-builder --win"
  },
  "devDependencies": {
    "@tiptap/extension-image": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/extension-task-item": "^2.10.3",
    "@tiptap/extension-task-list": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.8.10",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "build": {
    "appId": "com.perceptyne.bludos",
    "productName": "Bludos",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "artifactName": "Bludos-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Bludos-Portable-${version}.${ext}"
    }
  }
}
